# ============================================================
# Файл: .env  (положить рядом с docker-compose.prod.yml на сервере)
# Сгенерируй JWT секреты на сервере командой: openssl rand -base64 64
# ============================================================

# ── Docker Hub ───────────────────────────────────────────────
DOCKERHUB_USERNAME=your_dockerhub_username
DOCKERHUB_IMAGE_API=tours-api
DOCKERHUB_IMAGE_WEB=tours-web

# ── PostgreSQL (на этом же сервере) ─────────────────────────
POSTGRES_USER=tours
POSTGRES_PASSWORD=Tours2024Prod!

# ── CORS & Cookies ───────────────────────────────────────────
WEB_ORIGIN=http://93.115.22.45:3000
COOKIE_DOMAIN=93.115.22.45

# ── JWT (замени на вывод: openssl rand -base64 64) ───────────
JWT_SECRET=REPLACE_WITH_openssl_rand_output
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_openssl_rand_output
JWT_REFRESH_EXPIRES_IN=7d

# ── URLs ─────────────────────────────────────────────────────
APP_URL=http://93.115.22.45:3000

# ── Email ────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=vibeclubtech@gmail.com
MAIL_PASS=ghtp bksqkztugygk
MAIL_FROM=Tours Travel <vibeclubtech@gmail.com>
ADMIN_NOTIFY_EMAIL=vibeclubtech@gmail.com

# ── Vercel Blob ──────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=
