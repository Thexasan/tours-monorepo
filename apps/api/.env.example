# Скопируй в .env.local

# База
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tours?schema=public"

# Порт API
PORT=4000

# CORS — список через запятую
WEB_ORIGIN=http://localhost:3000

# Куки
COOKIE_DOMAIN=localhost

# JWT
JWT_SECRET="REPLACE_ME_WITH_RANDOM_64_CHAR_STRING"
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET="REPLACE_ME_WITH_ANOTHER_RANDOM_STRING"
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL для ссылок в email
APP_URL=http://localhost:3000

# Email (Resend) — добавим в Day 6
RESEND_API_KEY=

# Storage (Vercel Blob) — добавим в Day 3
BLOB_READ_WRITE_TOKEN=
