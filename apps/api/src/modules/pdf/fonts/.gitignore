# Font files are not committed to the repo (licensing).
# For local dev on Windows: copy C:\Windows\Fonts\arial.ttf → Arial-Regular.ttf
#                           copy C:\Windows\Fonts\arialbd.ttf → Arial-Bold.ttf
# For production (Linux): set env vars PDF_FONT_REGULAR / PDF_FONT_BOLD
#   (e.g. /usr/share/fonts/truetype/dejavu/DejaVuSans.ttf)
# OR: apt-get install -y fonts-dejavu in your Dockerfile/buildpack
*.ttf
*.otf
